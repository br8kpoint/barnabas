# --- Supabase ---
# From Supabase dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# service role key is used ONLY by server-side scripts (sync, reminders) — never expose to browser
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- App URL (used in email links + OAuth redirects) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- YouTube Data API v3 (for playlist sync) ---
# Create at https://console.cloud.google.com -> APIs & Services -> Credentials
YOUTUBE_API_KEY=YOUR-YOUTUBE-API-KEY
YOUTUBE_PLAYLIST_ID=PLfNVqWlknkohmH-Jszcwtanlr703lxoR5

# --- Resend (transactional email for daily reminders) ---
# Create at https://resend.com
RESEND_API_KEY=re_YOUR-KEY
REMINDER_FROM_EMAIL=barnabas@yourdomain.com

# --- Cron auth ---
# Shared secret between Vercel Cron and the /api/cron/* endpoints.
# Generate with: openssl rand -hex 32
CRON_SECRET=YOUR-RANDOM-SECRET

# --- Web Push (VAPID) ---
# Generate a pair with: npx web-push generate-vapid-keys --json
# Public key is exposed to the browser; private key stays server-only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=YOUR-VAPID-PUBLIC-KEY
VAPID_PRIVATE_KEY=YOUR-VAPID-PRIVATE-KEY
VAPID_SUBJECT=mailto:you@example.com

# --- Auth.js (NextAuth v5) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=YOUR-AUTH-SECRET

# Trusted origin for callbacks. In production this is your app domain.
# Locally Auth.js infers this from the request; the explicit setting silences warnings.
AUTH_URL=http://localhost:3000

# Google OAuth (same client used today, just additional redirect URI on our domain)
AUTH_GOOGLE_ID=YOUR-GOOGLE-CLIENT-ID
AUTH_GOOGLE_SECRET=YOUR-GOOGLE-CLIENT-SECRET

# Microsoft Entra ID (Azure) — same app registration, additional redirect URI on our domain.
# Issuer = "common" lets personal + work accounts both sign in.
AUTH_MICROSOFT_ENTRA_ID_ID=YOUR-AZURE-CLIENT-ID
AUTH_MICROSOFT_ENTRA_ID_SECRET=YOUR-AZURE-CLIENT-SECRET
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/common/v2.0

# GitHub OAuth — create a new OAuth App at https://github.com/settings/developers
# with redirect URI https://barnabasbible.app/api/auth/callback/github
AUTH_GITHUB_ID=YOUR-GITHUB-CLIENT-ID
AUTH_GITHUB_SECRET=YOUR-GITHUB-CLIENT-SECRET
